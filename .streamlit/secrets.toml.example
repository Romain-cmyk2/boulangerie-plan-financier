# Configuration secrète pour Streamlit Community Cloud.
# Copie ce fichier en `secrets.toml` et remplis les valeurs réelles.
# Ne JAMAIS committer secrets.toml — il est dans .gitignore.

# ─── Code d'édition de l'application ──────────────────────────────────────
# Remplace le code par défaut "mpl2026" en mode local.
CODE_EDITION = "mpl2026"

# ─── Synchronisation GitHub (persistance des plans) ──────────────────────
# Sans ces 3 valeurs, l'app fonctionne en mode local (ok pour dev, mais sur
# Streamlit Cloud les plans sont perdus à chaque redéploiement).
#
# Pour configurer :
# 1. Crée un fine-grained personal access token sur
#    https://github.com/settings/personal-access-tokens/new
#    - Repository access : "Only select repositories" → ton repo
#    - Permissions : Repository → Contents → Read and write
# 2. Renseigne le token, le nom du repo (owner/repo) et la branche.

GITHUB_TOKEN  = "github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
GITHUB_REPO   = "Romain-cmyk2/boulangerie-plan-financier"
GITHUB_BRANCH = "main"
